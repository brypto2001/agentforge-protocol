{
  "name": "agentforge-v3",
  "version": "3.0.0",
  "description": "AgentForge Protocol — Complete working version with real DeFi integrations",
  "private": true,
  "engines": {
    "node": ">=18 <=22"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:base-test": "hardhat run scripts/deploy.ts --network baseGoerli",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "setup": "node scripts/setup.js",
    "server": "node server/server.js",
    "start": "node server/server.js",
    "agent:yield": "AGENT_TYPE=yield ts-node sdk/agent-runner.ts",
    "agent:arb": "AGENT_TYPE=arbitrage ts-node sdk/agent-runner.ts",
    "agent:oracle": "AGENT_TYPE=oracle ts-node sdk/agent-runner.ts",
    "dashboard:install": "cd dashboard && npm install",
    "dashboard:dev": "cd dashboard && npm start",
    "dashboard:build": "cd dashboard && npm run build",
    "docker:up": "cd docker && docker compose up -d",
    "docker:down": "cd docker && docker compose down",
    "docker:logs": "cd docker && docker compose logs -f",
    "docker:rebuild": "cd docker && docker compose up -d --build"
  },
  "dependencies": {
    "@chainlink/contracts": "^0.8.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.1",
    "express": "^4.18.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/ignition-core": "^0.15.0",
    "@openzeppelin/hardhat-upgrades": "^3.1.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/better-sqlite3": "^7.6.9",
    "@types/chai": "^4.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.10",
    "chai": "^6.2.2",
    "hardhat": "^2.22.2",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.1",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.0",
    "typescript": "^5.4.3"
  }
}
