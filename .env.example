# ════════════════════════════════════════════════════════════════
# AgentForge — Complete Environment Configuration
# Copy this file to .env and fill in YOUR values
# NEVER commit .env to git
# ════════════════════════════════════════════════════════════════

# ── Blockchain ────────────────────────────────────────────────────
# Your Base mainnet RPC from Alchemy
# Get free key at: https://alchemy.com
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Ethereum mainnet (optional, for cross-chain agents)
ETHEREUM_RPC_URL=

# ── Contract Addresses (filled after deployment) ──────────────────
# These are set automatically by the deploy script in deployments.json
REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
COMMERCE_ADDRESS=0x0000000000000000000000000000000000000000
VAULT_ADDRESS=0x0000000000000000000000000000000000000000
EXECUTOR_ADDRESS=0x0000000000000000000000000000000000000000

# Block number when contracts were deployed (for event sync)
# Find this on basescan.org after deployment
DEPLOY_BLOCK=0

# ── Wallet Keys ────────────────────────────────────────────────────
# DEPLOYER: Used to deploy contracts (needs ~0.05 ETH on Base)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# AGENTS: Each agent needs its own wallet with ETH for gas
# and the tokens it will manage (USDC for yield, etc.)
# Generate new wallets: node -e "const {Wallet}=require('ethers');console.log(Wallet.createRandom().privateKey)"
YIELD_AGENT_PRIVATE_KEY=0xYOUR_YIELD_AGENT_KEY
ARB_AGENT_PRIVATE_KEY=0xYOUR_ARB_AGENT_KEY
ORACLE_AGENT_PRIVATE_KEY=0xYOUR_ORACLE_AGENT_KEY

# ── API Keys ──────────────────────────────────────────────────────
# BaseScan — for contract verification
# Get free key at: https://basescan.org/myapikey
BASESCAN_API_KEY=YOUR_BASESCAN_KEY

# LLM — for autonomous agent reasoning (optional but recommended)
# Anthropic: https://console.anthropic.com
# OpenAI: https://platform.openai.com/api-keys
LLM_API_KEY=sk-ant-YOUR_KEY_HERE
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6

# ── Agent Configuration ───────────────────────────────────────────
# Yield agent: how much USDC to manage
YIELD_POSITION_USDC=1000

# Arb agent: minimum profit in USD to execute a trade
ARB_MIN_PROFIT_USD=5

# Oracle: address of your deployed OracleStorage contract
# Leave blank to run in sign-only mode (no on-chain publishing)
ORACLE_STORAGE_CONTRACT=

# How often agents check for opportunities (milliseconds)
# Yield: every 5 min, Arb: every 30s, Oracle: every 60s
LOOP_INTERVAL_MS=300000

# ── Server ────────────────────────────────────────────────────────
# Backend server port
PORT=4000

# Your Vercel dashboard URL (for CORS)
# Set after deploying dashboard, e.g: https://agentforge.vercel.app
DASHBOARD_URL=http://localhost:3000

# ── Dashboard (React env vars — must start with REACT_APP_) ───────
REACT_APP_API_URL=http://localhost:4000
REACT_APP_WS_URL=ws://localhost:4000
REACT_APP_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REACT_APP_COMMERCE_ADDRESS=0x0000000000000000000000000000000000000000
REACT_APP_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
REACT_APP_EXECUTOR_ADDRESS=0x0000000000000000000000000000000000000000
REACT_APP_CHAIN_ID=8453

# ── Monitoring (optional) ─────────────────────────────────────────
GRAFANA_PASSWORD=changeme_before_production

# ── Security ──────────────────────────────────────────────────────
# JWT secret for API auth (generate: openssl rand -hex 32)
JWT_SECRET=generate_a_random_string_here
